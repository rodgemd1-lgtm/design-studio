{
  "manifest_version": 3,
  "name": "UX Design Scraper",
  "version": "10.0.0",
  "description": "AI-powered UX/UI design intelligence — MCP server, DTCG tokens, live DOM extraction, Claude integration, 7-phase design workflow",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "offscreen",
    "downloads",
    "sidePanel",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "UX Design Scraper"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "content_scripts": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
